{
  "headers": [
    {
      "source": "/api/webhook-gumroad",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/scan",
      "schedule": "46 13 * * 1-5"
    },
    {
      "path": "/api/evaluate",
      "schedule": "0 20 * * 1-5"
    }
  ]
}
